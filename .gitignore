# 八字排盘系统 - Git忽略规则

# 环境变量文件（包含API密钥）
.env

# 数据库文件
*.db
*.sqlite
*.sqlite3

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# IDE配置
.vscode/
.idea/
*.swp
*.swo

# 测试文件
test_*.py
*_test.py
tests/

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.temp
.cache/

# 系统文件
.DS_Store
Thumbs.db

# 打包文件
dist/
build/
*.egg-info/